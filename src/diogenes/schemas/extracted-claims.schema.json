{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/wphillipmoore/ai-research-methodology/main/src/diogenes/schemas/extracted-claims.schema.json",
  "title": "Extracted Claims",
  "description": "Claims extracted from a document for verification. Output of /research extract. Can be used directly as input to /research run or dio run.",
  "type": "object",
  "required": ["source", "extracted_at", "claims"],
  "properties": {
    "source": {
      "type": "string",
      "description": "URL or file path of the source document."
    },
    "extracted_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of extraction."
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The verifiable factual claim as it appears in the prose."
          },
          "context": {
            "type": "string",
            "description": "Brief context for where this claim appears in the document."
          }
        },
        "additionalProperties": false
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "description": "Empty by default — user may add queries before running verification."
    },
    "axioms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "description": "Empty by default — user may add axioms before running verification."
    }
  },
  "additionalProperties": false
}
