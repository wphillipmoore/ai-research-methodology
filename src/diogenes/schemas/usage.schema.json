{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/wphillipmoore/ai-research-methodology/main/src/diogenes/schemas/usage.schema.json",
  "title": "Usage Report",
  "description": "Token usage, cost estimates, and API call tracking for a research run.",
  "type": "object",
  "required": ["totals", "per_call"],
  "properties": {
    "totals": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens", "api_calls", "estimated_cost_usd"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "web_search_requests": { "type": "integer", "minimum": 0 },
        "web_fetch_requests": { "type": "integer", "minimum": 0 },
        "api_calls": { "type": "integer", "minimum": 0 },
        "estimated_cost_usd": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "per_call": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "model", "input_tokens", "output_tokens"],
        "properties": {
          "agent": { "type": "string", "description": "Sub-agent name." },
          "model": { "type": "string", "description": "Model ID used." },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "cache_creation_tokens": { "type": "integer", "minimum": 0 },
          "cache_read_tokens": { "type": "integer", "minimum": 0 },
          "web_search_requests": { "type": "integer", "minimum": 0 },
          "web_fetch_requests": { "type": "integer", "minimum": 0 },
          "service_tier": { "type": "string" },
          "estimated_cost_usd": { "type": "number", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
